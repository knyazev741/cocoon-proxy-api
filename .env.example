# Required: Your TON wallet address for receiving user deposits
COCOON_DEPOSIT_WALLET=

# Cocoon client upstream URL
# COCOON_UPSTREAM_URL=http://localhost:10000

# Database path
# COCOON_DATABASE_PATH=./data/cocoon_proxy.db

# Server settings
# COCOON_HOST=0.0.0.0
# COCOON_PORT=8000

# Pricing multiplier applied to network costs
# COCOON_MARKUP_MULTIPLIER=1.5

# Minimum balance required to make a request (in TON)
# COCOON_MIN_BALANCE_TON=0.01

# Maximum allowed negative balance (in TON)
# COCOON_MAX_OVERDRAFT_TON=0.05

# tonapi.io API key (optional, improves deposit detection reliability)
# COCOON_TONAPI_KEY=

# Admin token for /v1/keys endpoint (if empty, open registration)
# COCOON_ADMIN_TOKEN=

# Maximum allowed max_tokens per request
# COCOON_MAX_TOKENS_CAP=128000
